<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Fitness Tracking Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<div class="container mt-5">

    <h2 class="text-center mb-4">
        Daily Fitness Tracking Dashboard
    </h2>

    <h5 class="text-center mb-4">
        Welcome, <%= user.username %>
    </h5>

    <!-- Nutrition Summary -->
    <div class="row text-center mb-4">

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Calories</h5>
                <p><%= user.consumed_calories %> / <%= user.target_calories %> kcal</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Protein</h5>
                <p><%= user.consumed_protein_g %> / <%= user.target_protein_g %> g</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Carbs</h5>
                <p><%= user.consumed_carbs_g %> / <%= user.target_carbs_g %> g</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Fat</h5>
                <p><%= user.consumed_fats_g %> / <%= user.target_fats_g %> g</p>
            </div>
        </div>

    </div>

    <!-- Progress Bars -->

    <h4>Daily Progress</h4>

    <p>Calories</p>
    <div class="progress mb-3">
        <div class="progress-bar bg-success"
             style="width:<%= user.caloriePercent %>%;">
            <%= user.caloriePercent %>%
        </div>
    </div>

    <p>Protein</p>
    <div class="progress mb-3">
        <div class="progress-bar bg-info"
             style="width:<%= user.proteinPercent %>%;">
            <%= user.proteinPercent %>%
        </div>
    </div>

    <p>Carbohydrates</p>
    <div class="progress mb-3">
        <div class="progress-bar bg-warning"
             style="width:<%= user.carbPercent %>%;">
            <%= user.carbPercent %>%
        </div>
    </div>

    <p>Fat</p>
    <div class="progress mb-4">
        <div class="progress-bar bg-danger"
             style="width:<%= user.fatPercent %>%;">
            <%= user.fatPercent %>%
        </div>
    </div>

    <!-- Remaining Nutrition -->

    <div class="card p-4 shadow-sm mb-4">

        <h4>Remaining Today</h4>

        <ul class="list-group">

            <li class="list-group-item">
                Calories Left:
                <strong><%= user.remainingCalories %> kcal</strong>
            </li>

            <li class="list-group-item">
                Protein Left:
                <strong><%= user.remainingProtein %> g</strong>
            </li>

            <li class="list-group-item">
                Carbs Left:
                <strong><%= user.remainingCarbs %> g</strong>
            </li>

            <li class="list-group-item">
                Fat Left:
                <strong><%= user.remainingFats %> g</strong>
            </li>

        </ul>

    </div>

    <!-- Status -->

    <div class="text-center">

        <% if(user.status === "Within Target"){ %>

            <div class="alert alert-success">
                ✅ You are within your daily nutrition target.
            </div>

        <% } else { %>

            <div class="alert alert-danger">
                ⚠ You have exceeded your daily nutrition target.
            </div>

        <% } %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>